<manifest xmlns:android="http://schemas.android.com/apk/res/android"
  package="com.sinnoor.open_mail_launcher">

  <!--
    Android 11+ package visibility — declares the intents this plugin
    issues so the OS allows queryIntentActivities/resolveActivity to see
    matching apps. These entries are merged into the consumer's
    AndroidManifest via the AGP manifest merger; no consumer action
    required.

    SENDTO + mailto: used by getMailApps() for discovery.
    SEND_MULTIPLE + message/rfc822: used by the attachment intent path.
  -->
  <queries>
    <intent>
      <action android:name="android.intent.action.SENDTO" />
      <data android:scheme="mailto" />
    </intent>
    <intent>
      <action android:name="android.intent.action.SEND_MULTIPLE" />
      <data android:mimeType="message/rfc822" />
    </intent>
  </queries>
</manifest>